{
  "name": "japanese",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rsbuild dev --host 0.0.0.0",
    "build": "rsbuild build",
    "generate:words": "bun scripts/generateWords.js",
    "preview": "rsbuild preview --host 0.0.0.0",
    "deploy": "bun run build && bunx wrangler pages deploy dist --project-name japanese-practice --branch master",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "bun test"
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.5",
    "@rsbuild/plugin-react": "^2.1.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "wanakana": "^5.3.1"
  }
}
